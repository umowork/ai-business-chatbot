     1|# AI Business Chatbot — .env.example
     2|# Copy to .env and fill in your values
     3|
     4|# ── Telegram ──────────────────────────────────────────────────────────
     5|BOT_TOKEN=your_telegram_bot_token_here
     6|ADMIN_IDS=123456789,987654321
     7|
     8|# ── Mode ──────────────────────────────────────────────────────────────
     9|MOCK_MODE=true                          # true = mock services (dev), false = real APIs
    10|DEBUG=false
    11|
    12|# ── CRM ───────────────────────────────────────────────────────────────
    13|CRM_PROVIDER=mock                       # mock | bitrix24 | amocrm
    14|BITRIX_WEBHOOK=https://your-domain.bitrix24.ru/rest/1/your_webhook_token/
    15|AMO_TOKEN=your_amocrm_oauth_token
    16|AMO_BASE_URL=https://your-subdomain.amocrm.ru
    17|
    18|# ── LLM ───────────────────────────────────────────────────────────────
    19|LLM_PROVIDER=openai                     # openai | gigachat | yandex
    20|OPENAI_API_KEY=sk-your-openai-api-key
    21|OPENAI_MODEL=gpt-4o-mini
    22|# OPENAI_BASE_URL=https://api.openai.com/v1  # Custom endpoint (optional)
    23|
    24|# GigaChat (Sber)
    25|# GIGACHAT_CREDENTIALS=your_gigachat_credentials
    26|# GIGACHAT_MODEL=GigaChat-20-1.5-h2o
    27|
    28|# YandexGPT (Yandex Cloud)
    29|# YANDEX_API_KEY=your_yandex_api_key
    30|# YANDEX_FOLDER_ID=your_yandex_folder_id
    31|# YANDEX_MODEL=yandexgpt-lite
    32|
    33|# ── RAG (Retrieval-Augmented Generation) ──────────────────────────────
    34|EMBEDDING_PROVIDER=openai               # openai | sentence-transformers
    35|DOCUMENTS_DIR=./documents               # Directory with PDF files
    36|CHUNK_SIZE=500                          # Character chunk size for splitting
    37|CHUNK_OVERLAP=50                        # Overlap between chunks
    38|RAG_TOP_K=3                             # Number of chunks to retrieve
    39|
    40|# ── Database ──────────────────────────────────────────────────────────
    41|DATABASE_URL=sqlite+aiosqlite:///bot.db # SQLite (dev) or postgresql+asyncpg://...
    42|
    43|# ── Redis / Background Tasks ──────────────────────────────────────────
    44|REDIS_URL=redis://localhost:6379/0
    45|
    46|# ── Business Configuration ────────────────────────────────────────────
    47|BUSINESS_NAME=Компания
    48|BUSINESS_TONALITY=Дружелюбный, профессиональный
    49|

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000
