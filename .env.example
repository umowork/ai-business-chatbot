# AI Business Chatbot — .env.example
# Copy to .env and fill in your values

# ── Telegram ──────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# ── Mode ──────────────────────────────────────────────────────────────
MOCK_MODE=true                          # true = mock services (dev), false = real APIs
DEBUG=false

# ── CRM ───────────────────────────────────────────────────────────────
CRM_PROVIDER=mock                       # mock | bitrix24 | amocrm
BITRIX_WEBHOOK=https://your-domain.bitrix24.ru/rest/1/your_webhook_token/
AMO_TOKEN=your_amocrm_oauth_token
AMO_BASE_URL=https://your-subdomain.amocrm.ru

# ── LLM ───────────────────────────────────────────────────────────────
LLM_PROVIDER=openai                     # openai | gigachat | yandex
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1  # Custom endpoint (optional)

# GigaChat (Sber)
# GIGACHAT_CREDENTIALS=your_gigachat_credentials
# GIGACHAT_MODEL=GigaChat-20-1.5-h2o
# GIGACHAT_VERIFY_SSL=true

# YandexGPT (Yandex Cloud)
# YANDEX_API_KEY=your_yandex_api_key
# YANDEX_FOLDER_ID=your_yandex_folder_id
# YANDEX_MODEL=yandexgpt-lite

# ── RAG (Retrieval-Augmented Generation) ──────────────────────────────
EMBEDDING_PROVIDER=openai               # openai | sentence-transformers
DOCUMENTS_DIR=./documents               # Directory with PDF files
CHUNK_SIZE=500                          # Character chunk size for splitting
CHUNK_OVERLAP=50                        # Overlap between chunks
RAG_TOP_K=3                             # Number of chunks to retrieve

# ── Database ──────────────────────────────────────────────────────────
# Production: postgresql+asyncpg://chatbot:chatbot@postgres:5432/chatbot
DATABASE_URL=sqlite+aiosqlite:///bot.db

# ── Redis / Background Tasks ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Business Configuration ────────────────────────────────────────────
BUSINESS_NAME=Компания
BUSINESS_TONALITY=Дружелюбный, профессиональный

# ── Web API ────────────────────────────────────────────────────────────
API_KEY=your-secret-key-here

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000
